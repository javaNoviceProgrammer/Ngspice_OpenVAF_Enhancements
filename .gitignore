.DS_Store

# Build outputs (regenerated by CI / local builds)
/OpenVAF-master-20260610/target/
ngspice-46/ci-build/
ngspice-46/build/
ngspice-46/build-x86/

# CI scratch
_artifacts/
out/

# ----------------------------------------------------------------------------
# ngspice: its own per-directory .gitignore files were removed so that source
# files they wrongly excluded (parser grammars, XSPICE table-model sources) get
# committed.  The patterns below keep the genuinely build-generated files out.
# ----------------------------------------------------------------------------

# object / libtool / archive outputs
*.o
*.lo
*.la
.libs/
.deps/

# editor & tool backup files
*~
\#*\#

# autotools-generated (regenerated by ngspice-46/autogen.sh)
ngspice-46/**/Makefile.in
ngspice-46/configure
ngspice-46/aclocal.m4
ngspice-46/config.guess
ngspice-46/config.sub
ngspice-46/ar-lib
ngspice-46/compile
ngspice-46/depcomp
ngspice-46/install-sh
ngspice-46/missing
ngspice-46/ylwrap
ngspice-46/m4/libtool.m4
ngspice-46/m4/lt*.m4
ngspice-46/**/config.h.in
ngspice-46/**/config.h
ngspice-46/**/config.status
ngspice-46/**/config.log
ngspice-46/**/stamp-h1
ngspice-46/autom4te.cache/

# bison/flex generated (regenerated from the committed .y/.l sources)
ngspice-46/src/frontend/parse-bison.c
ngspice-46/src/frontend/parse-bison.h
ngspice-46/src/spicelib/parser/inpptree-parser.c
ngspice-46/src/spicelib/parser/inpptree-parser.h
ngspice-46/src/xspice/cmpp/ifs_lex.c
ngspice-46/src/xspice/cmpp/ifs_yacc.c
ngspice-46/src/xspice/cmpp/ifs_yacc.h
ngspice-46/src/xspice/cmpp/mod_lex.c
ngspice-46/src/xspice/cmpp/mod_yacc.c
ngspice-46/src/xspice/cmpp/mod_yacc.h

# XSPICE code-model build outputs (regenerated by cmpp during the build)
*.cm
ngspice-46/src/xspice/icm/**/cminfo.h
ngspice-46/src/xspice/icm/**/cminfo2.h
ngspice-46/src/xspice/icm/**/cmextrn.h
ngspice-46/src/xspice/icm/**/udninfo.h
ngspice-46/src/xspice/icm/**/udninfo2.h
ngspice-46/src/xspice/icm/**/udnextrn.h
ngspice-46/src/xspice/icm/**/objects.inc

# ngspice test-suite run outputs (not needed to build the binaries)
ngspice-46/tests/**/*.out

# stray top-level build products
ngspice-46/src/ngspice
ngspice-46/ngspice.pc
ngspice-46/ltmain.sh

# absdelay scripts: per-platform compiled model + temp netlists
absdelay_examples/.build/
absdelay_examples/**/.k.cir
absdelay_examples/**/.s.cir
absdelay_examples/benchmark/cir/
