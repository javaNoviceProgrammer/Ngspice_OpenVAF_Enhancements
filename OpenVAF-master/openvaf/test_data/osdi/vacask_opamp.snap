param "$mfactor"
units = "", desc = "Multiplier (Verilog-A $mfactor)", flags = ParameterFlags(PARA_KIND_INST)
param "rin"
units = "Ohm", desc = "Input resistance", flags = ParameterFlags(PARA_KIND_INST)
param "rout"
units = "Ohm", desc = "Output resistance", flags = ParameterFlags(PARA_KIND_INST)
param "gain"
units = "", desc = "Gain", flags = ParameterFlags(PARA_KIND_INST)
param "cmgain"
units = "", desc = "Common mode gain", flags = ParameterFlags(PARA_KIND_INST)
param "va"
units = "V", desc = "Positive saturation", flags = ParameterFlags(PARA_KIND_INST)
param "vb"
units = "V", desc = "Negative saturation", flags = ParameterFlags(PARA_KIND_INST)
param "voffs"
units = "V", desc = "Input offset", flags = ParameterFlags(PARA_KIND_INST)
param "fp1"
units = "Hz", desc = "Pole frequency #1", flags = ParameterFlags(PARA_KIND_INST)
param "fp2"
units = "Hz", desc = "Pole frequency #2", flags = ParameterFlags(PARA_KIND_INST)
param "fp3"
units = "Hz", desc = "Pole frequency #3", flags = ParameterFlags(PARA_KIND_INST)

3 terminals
node "p" units = "V", runits = "A"
node "n" units = "V", runits = "A"
node "out" units = "V", runits = "A"
node "pn1" units = "V", runits = "A"
node "pn2" units = "V", runits = "A"
node "pn3" units = "V", runits = "A"
jacobian (p, p) JacobianFlags(JACOBIAN_ENTRY_RESIST | JACOBIAN_ENTRY_REACT_CONST)
jacobian (p, n) JacobianFlags(JACOBIAN_ENTRY_RESIST | JACOBIAN_ENTRY_REACT_CONST)
jacobian (n, p) JacobianFlags(JACOBIAN_ENTRY_RESIST | JACOBIAN_ENTRY_REACT_CONST)
jacobian (n, n) JacobianFlags(JACOBIAN_ENTRY_RESIST | JACOBIAN_ENTRY_REACT_CONST)
jacobian (out, p) JacobianFlags(JACOBIAN_ENTRY_RESIST | JACOBIAN_ENTRY_REACT_CONST)
jacobian (out, n) JacobianFlags(JACOBIAN_ENTRY_RESIST | JACOBIAN_ENTRY_REACT_CONST)
jacobian (out, out) JacobianFlags(JACOBIAN_ENTRY_RESIST | JACOBIAN_ENTRY_REACT_CONST)
jacobian (out, pn1) JacobianFlags(JACOBIAN_ENTRY_RESIST | JACOBIAN_ENTRY_REACT_CONST)
jacobian (out, pn2) JacobianFlags(JACOBIAN_ENTRY_RESIST | JACOBIAN_ENTRY_REACT_CONST)
jacobian (out, pn3) JacobianFlags(JACOBIAN_ENTRY_RESIST | JACOBIAN_ENTRY_REACT_CONST)
jacobian (pn1, p) JacobianFlags(JACOBIAN_ENTRY_RESIST | JACOBIAN_ENTRY_REACT_CONST)
jacobian (pn1, n) JacobianFlags(JACOBIAN_ENTRY_RESIST | JACOBIAN_ENTRY_REACT_CONST)
jacobian (pn1, pn1) JacobianFlags(JACOBIAN_ENTRY_RESIST | JACOBIAN_ENTRY_REACT)
jacobian (pn2, pn1) JacobianFlags(JACOBIAN_ENTRY_RESIST | JACOBIAN_ENTRY_REACT_CONST)
jacobian (pn2, pn2) JacobianFlags(JACOBIAN_ENTRY_RESIST | JACOBIAN_ENTRY_REACT)
jacobian (pn3, pn2) JacobianFlags(JACOBIAN_ENTRY_RESIST | JACOBIAN_ENTRY_REACT_CONST)
jacobian (pn3, pn3) JacobianFlags(JACOBIAN_ENTRY_RESIST | JACOBIAN_ENTRY_REACT)
0 states
has bound_step false
